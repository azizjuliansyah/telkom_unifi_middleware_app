{
  "type": "module",
  "name": "unifi-captive-middleware",
  "version": "1.0.0",
  "description": "Unifi Captive Portal Middleware dengan Local User Management",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "concurrently \"npm run server\" \"npm run watch:css\" \"npm run watch:browser\"",
    "server": "node --watch src/index.js",
    "build:css": "tailwindcss -i ./src/public/css/input.css -o ./src/public/css/main.css",
    "watch:css": "tailwindcss -i ./src/public/css/input.css -o ./src/public/css/main.css --watch",
    "watch:browser": "browser-sync start --proxy \"localhost:3000\" --files \"src/views/**/*.html, src/public/**/*\" --no-notify"
  },
  "keywords": [
    "unifi",
    "captive-portal",
    "middleware"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.6",
    "dotenv": "^16.3.1",
    "ejs": "^5.0.2",
    "express": "^4.18.2",
    "express-session": "^1.17.3",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "morgan": "^1.10.0",
    "pg": "^8.11.3",
    "uuid": "^9.0.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.4",
    "autoprefixer": "^10.5.0",
    "browser-sync": "^3.0.4",
    "concurrently": "^9.2.1",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.2.4"
  }
}
