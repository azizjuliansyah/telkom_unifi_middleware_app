<%- include('layouts/header', { 
    title: 'Masuk ke Jaringan - Unifi Captive Portal', 
    bodyClass: 'bg-gray-50 h-screen overflow-hidden' 
}) %>
    <div class="flex h-full">
        <!-- Left Section (70%) -->
        <div class="hidden lg:block w-[70%] relative overflow-hidden">
            <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 hover:scale-105"
                style="background-image: url('/images/login-placeholder.png');">
            </div>
            <div class="absolute inset-0 bg-black/20"></div>
        </div>

        <!-- Right Section (30%) -->
        <div
            class="w-full lg:w-[35%] flex flex-col pt-12 px-10 sm:px-16 lg:px-20 bg-white z-10 shadow-2xl overflow-y-auto">
            <!-- Logo Top -->
            <div class="mb-8 flex justify-center">
                <div class="flex flex-col items-center">
                    <img src="/images/telkominfra-favicon.png" alt="TelkomInfra Logo" class="w-16 h-16 object-contain">
                    <span class="text-xs font-semibold tracking-[0.3em] text-gray-400 uppercase mt-4">Portal
                        Application</span>
                </div>
            </div>

            <div class="space-y-2 mb-10 text-center">
                <h1 class="text-3xl font-bold text-on-surface tracking-tight">Selamat Datang!</h1>
                <p class="text-outline text-sm">Silakan masukkan kredensial Anda untuk mengakses jaringan.</p>
            </div>



            <form id="login-form" class="space-y-3">
                <%- include('components/input', {
                    id: 'username',
                    label: 'Username',
                    icon: 'person',
                    placeholder: 'Enter your username',
                    required: true,
                    className: 'h-12'
                }) %>

                <%- include('components/input', {
                    id: 'password',
                    type: 'password',
                    label: 'Password',
                    icon: 'lock',
                    placeholder: '••••••••',
                    required: true,
                    showPasswordToggle: true,
                    className: 'h-12'
                }) %>

                <div class="pt-2">
                    <%- include('components/button', {
                        id: 'submit-btn',
                        submit: true,
                        text: 'SIGN IN TO NETWORK',
                        variant: 'primary',
                        className: 'w-full h-12'
                    }) %>
                </div>

                <div class="text-center">
                    <a href="#" id="forgot-password-link"
                        class="text-xs font-bold text-primary hover:underline uppercase tracking-wider">Forgot Password?</a>
                </div>
            </form>

            <!-- Footer Branding -->
            <div class="py-8">
                <%- include('partials/footer-logos') %>
            </div>
        </div>
    </div>

<% const loginScripts = `
    <script src="/js/login.js"></script>
`; %>

<%- include('layouts/footer', { extraScripts: loginScripts }) %>