<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head') %>
  <title>Masuk ke Jaringan - Unifi Captive Portal</title>
</head>
<body class="bg-gray-50 h-screen overflow-hidden">
  <div class="flex h-full">
    <!-- Left Section (70%) -->
    <div class="hidden lg:block w-[70%] relative overflow-hidden">
      <div class="absolute inset-0 bg-cover bg-center transition-transform duration-700 hover:scale-105" 
           style="background-image: url('/images/login-bg.jpg');">
      </div>
      <div class="absolute inset-0 bg-black/20"></div>
    </div>

    <!-- Right Section (30%) -->
    <div class="w-full lg:w-[35%] flex flex-col pt-20 lg:pt-32 px-10 sm:px-16 lg:px-20 bg-white z-10 shadow-2xl overflow-y-auto">
      <!-- Logo Top -->
      <div class="mb-8 flex justify-center">
        <div class="flex flex-col items-center">
          <img src="/images/telkominfra-favicon.png" alt="TelkomInfra Logo" class="w-16 h-16 object-contain">
          <span class="text-xs font-semibold tracking-[0.3em] text-gray-400 uppercase mt-4">Portal Application</span>
        </div>
      </div>

      <div class="space-y-3 mb-10 text-center">
        <h1 class="text-4xl font-black text-gray-900 tracking-tight">Selamat Datang!</h1>
        <p class="text-gray-500 text-sm font-medium">Silakan masukkan kredensial Anda untuk mengakses jaringan.</p>
      </div>

      <div id="error-msg" class="hidden mb-6 p-4 bg-red-50 border border-red-200 text-red-600 rounded-md text-sm animate-pulse"></div>
      <div id="success-msg" class="hidden mb-6 p-4 bg-green-50 border border-green-200 text-green-600 rounded-md text-sm"></div>

      <form id="login-form" class="space-y-3">
        <div>
          <label for="username" class="block text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-3 ml-1">Username</label>
          <input type="text" id="username" name="username" required
                 class="w-full px-5 py-4 bg-gray-50 border border-gray-100 rounded-2xl focus:ring-2 focus:ring-red-600 focus:border-red-600 transition-all outline-none text-gray-900 placeholder-gray-300 text-sm"
                 placeholder="Masukkan username Anda">
        </div>
        <div>
          <label for="password" class="block text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] mb-3 ml-1">Password</label>
          <input type="password" id="password" name="password" required
                 class="w-full px-5 py-4 bg-gray-50 border border-gray-100 rounded-2xl focus:ring-2 focus:ring-red-600 focus:border-red-600 transition-all outline-none text-gray-900 placeholder-gray-300 text-sm"
                 placeholder="Masukkan password">
        </div>

        <button type="submit" id="submit-btn" 
                class="w-full py-4 bg-red-600 hover:bg-red-700 text-white font-black text-sm uppercase tracking-[0.2em] rounded-2xl shadow-xl shadow-red-100 transform transition-all hover:-translate-y-1 active:scale-95">
          Masuk Sekarang
        </button>

        <div class="text-center pt-4">
          <a href="#" id="forgot-password-link" class="text-[10px] font-black text-red-600 uppercase tracking-[0.2em] hover:text-red-700 transition-colors">Lupa Password?</a>
        </div>
      </form>

      <!-- Footer Branding -->
      <div class="py-8">
        <%- include('partials/footer-logos') %>
      </div>
    </div>
  </div>

  <script src="/js/login.js"></script>
</body>
</html>
