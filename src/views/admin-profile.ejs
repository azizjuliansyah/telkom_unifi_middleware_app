<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head') %>
  <title>Profil Saya - Admin Portal</title>
</head>
<body class="bg-gray-50 flex flex-col h-screen overflow-hidden">
  
  <%- include('partials/admin-header') %>

  <!-- Main Content -->
  <main class="flex-1 overflow-auto p-8">
    <div class="max-w-2xl mx-auto">
      <div class="mb-8">
        <h2 class="text-2xl font-black text-gray-900 tracking-tight">Profil Saya</h2>
        <p class="text-gray-500 font-medium">Kelola informasi akun dan keamanan dashboard Anda.</p>
      </div>

      <div class="bg-white rounded-[2rem] shadow-sm border border-gray-100 overflow-hidden">
        <!-- Profile Header -->
        <div class="px-8 py-10 bg-gray-50/50 border-b border-gray-100 flex items-center space-x-6">
          <div class="w-20 h-20 bg-red-600 rounded-3xl flex items-center justify-center text-white text-3xl font-black shadow-xl shadow-red-100 uppercase">
            <%= admin.initials %>
          </div>
          <div>
            <h3 class="text-xl font-bold text-gray-900"><%= admin.username %></h3>
            <p class="text-sm text-gray-400 font-bold uppercase tracking-widest mt-1">Super Administrator</p>
          </div>
        </div>

        <div class="p-8">
          <form id="profile-form" class="space-y-6">
            <div class="grid grid-cols-1 gap-6">
              <div>
                <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-3 ml-1">Username</label>
                <input type="text" value="<%= admin.username %>" disabled
                       class="w-full px-5 py-4 bg-gray-50 border border-gray-100 rounded-2xl text-gray-400 font-bold cursor-not-allowed text-sm">
                <p class="text-[10px] text-gray-400 mt-2 ml-1 italic">* Username tidak dapat diubah untuk alasan keamanan.</p>
              </div>

              <div class="pt-4 border-t border-gray-50">
                <h4 class="text-sm font-black text-gray-900 mb-6 uppercase tracking-wider">Ubah Password</h4>
                
                <div class="space-y-5">
                  <div>
                    <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Password Baru</label>
                    <input type="password" id="new-password" placeholder="Masukkan password baru"
                           class="w-full px-5 py-4 bg-gray-50 border border-gray-100 rounded-2xl focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all outline-none text-sm">
                  </div>
                  <div>
                    <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Konfirmasi Password Baru</label>
                    <input type="password" id="confirm-password" placeholder="Ulangi password baru"
                           class="w-full px-5 py-4 bg-gray-50 border border-gray-100 rounded-2xl focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all outline-none text-sm">
                  </div>
                </div>
              </div>
            </div>

            <div id="form-message" class="hidden p-4 rounded-2xl text-sm font-medium"></div>

            <div class="pt-6">
              <button type="submit" id="save-profile-btn" 
                      class="w-full py-4 bg-red-600 hover:bg-red-700 text-white text-xs font-black uppercase tracking-[0.2em] rounded-2xl shadow-xl shadow-red-100 transition-all active:scale-95 disabled:opacity-50">
                Simpan Perubahan
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </main>

  <script src="/js/admin-profile.js"></script>
</body>
</html>
