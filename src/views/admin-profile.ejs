<%- include('layouts/header', { title: 'Edit Profile - Telkom Admin' }) %>
  
  <%- include('partials/admin-header') %>

  <!-- Main Content -->
  <main class="mt-16 flex-grow max-w-container-max-width mx-auto w-full px-margin-x py-margin-y">
    <!-- Breadcrumbs -->
    <%- include('components/breadcrumb', {
      items: [
        { label: 'Dashboard', href: '/admin' },
        { label: 'Edit Profile', active: true }
      ]
    }) %>


    <!-- Header Section -->
    <div class="mb-stack-sm">
      <h1 class="text-3xl font-extrabold tracking-tight text-on-surface mb-1">Account Settings</h1>
      <p class="text-[15px] text-on-secondary-container font-medium">Manage your personal information, security, and preferences.</p>
    </div>

    <!-- Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 items-start">
      
      <!-- Left Column: Profile Preview -->
      <div class="lg:col-span-4 space-y-6">
        <%- include('components/card', {
          className: 'p-8 flex flex-col items-center text-center',
          bodyClassName: 'w-full',
          body: `
            <div class="relative group inline-block">
              <div class="w-32 h-32 bg-primary rounded-full flex items-center justify-center text-white text-5xl font-black shadow-2xl shadow-red-100 uppercase mb-6 transition-transform group-hover:scale-105 duration-300 mx-auto">
                ${admin.initials}
              </div>
            </div>
            
            <h2 class="text-xl font-extrabold text-on-surface mb-1">${admin.username}</h2>
            <div class="px-4 py-1.5 bg-primary-container text-on-primary-container text-[11px] font-black rounded-full uppercase tracking-widest mb-8 inline-block">
              Super Administrator
            </div>
          `
        }) %>




      </div>

      <!-- Right Column: Edit Form -->
      <div class="lg:col-span-8">
        <form id="profile-form" class="space-y-4">
          <!-- Account Info Section -->
          <%
            const accountInfoBody = `
              <div class="space-y-6">
                ${ include('components/input', {
                  id: 'username-display',
                  label: 'Username',
                  value: admin.username,
                  disabled: true,
                  icon: 'person',
                  hint: include('components/icon', { name: 'lock', className: 'w-3.5 h-3.5 inline mr-1' }) + ' Username cannot be changed for security reasons.'
                }) }
              </div>
            `;
          %>
          <%- include('components/card', {
            title: 'Account Information',
            icon: 'badge',
            body: accountInfoBody
          }) %>


          <!-- Password Section -->
          <%
            const securityBody = `
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                ${ include('components/input', {
                  id: 'new-password',
                  type: 'password',
                  label: 'New Password',
                  icon: 'lock_open',
                  placeholder: '••••••••',
                  showPasswordToggle: true
                }) }
                ${ include('components/input', {
                  id: 'confirm-password',
                  type: 'password',
                  label: 'Confirm Password',
                  icon: 'verified',
                  placeholder: '••••••••',
                  showPasswordToggle: true
                }) }
              </div>

              <div class="mt-6 flex items-start gap-4 p-5 bg-surface-container-low rounded-xl border border-outline-variant">
                <div class="text-primary">
                  ${ include('components/icon', { name: 'info', className: 'w-5 h-5' }) }
                </div>
                <div>
                  <h4 class="text-sm font-bold text-on-surface mb-1">Security Tip</h4>
                  <p class="text-xs text-on-secondary-container leading-relaxed">Ensure your password is at least 8 characters long and contains a mix of letters, numbers, and symbols.</p>
                </div>
              </div>



              <div class="pt-6 flex justify-end">
                ${ include('components/button', {
                  id: 'save-profile-btn',
                  submit: true,
                  text: 'SAVE CHANGES',
                  icon: 'save',
                  variant: 'primary',
                  size: 'sm',
                  className: 'w-full md:w-auto'
                }) }
              </div>
            `;
          %>

          <%- include('components/card', {
            title: 'Security & Password',
            icon: 'security',
            body: securityBody
          }) %>


        </form>
      </div>
    </div>
  </main>

<%- include('layouts/footer', { extraScripts: '<script src="/js/admin-profile.js"></script>' }) %>

