<%- include('layouts/header', { title: 'Edit Profile - Telkom Admin' }) %>
  
  <%- include('partials/admin-header') %>

  <!-- Main Content -->
  <main class="mt-16 flex-grow max-w-container-max-width mx-auto w-full px-margin-x py-margin-y">
    <!-- Breadcrumbs -->
    <%- include('components/breadcrumb', {
      items: [
        { label: 'Dashboard', href: '/admin' },
        { label: 'Edit Profile', active: true }
      ]
    }) %>


    <!-- Header Section -->
    <div class="mb-stack-sm">
      <h1 class="text-3xl font-extrabold tracking-tight text-on-surface mb-1">Account Settings</h1>
      <p class="text-[15px] text-on-secondary-container font-medium">Manage your personal information, security, and preferences.</p>
    </div>

    <!-- Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-4 items-start">
      
      <!-- Left Column: Profile Preview -->
      <div class="lg:col-span-4 space-y-6">
        <%- include('components/card', {
          className: 'p-8 flex flex-col items-center text-center',
          bodyClassName: 'w-full',
          body: `
            <div class="relative group inline-block">
              <div class="w-32 h-32 bg-primary rounded-full flex items-center justify-center text-white text-5xl font-black shadow-2xl shadow-red-100 uppercase mb-6 transition-transform group-hover:scale-105 duration-300 mx-auto">
                ${admin.initials}
              </div>
            </div>
            
            <h2 class="text-xl font-extrabold text-on-surface mb-1">${admin.username}</h2>
            <div class="px-4 py-1.5 bg-primary-container text-on-primary-container text-[11px] font-black rounded-full uppercase tracking-widest mb-8 inline-block">
              Super Administrator
            </div>
          `
        }) %>




      </div>

      <!-- Right Column: Edit Form -->
      <div class="lg:col-span-8">
        <form id="profile-form" class="space-y-4">
          <!-- Account Info Section -->
          <%
            // Helper to render input without nested include tags
            const renderInput = (args) => {
              const { id, label, icon, type, placeholder, required, className, hint, value, disabled, showPasswordToggle } = args;
              return `
                <div class="space-y-1.5 ${className || ''}">
                  ${label ? `<label for="${id}" class="block text-xs font-bold text-on-secondary-container uppercase tracking-widest">${label}</label>` : ''}
                  <div class="relative group">
                    ${icon ? `<span class="material-symbols-outlined absolute left-4 top-0 bottom-0 flex items-center text-on-secondary-container text-xl leading-none transition-colors group-focus-within:text-primary">${icon}</span>` : ''}
                    <input 
                      id="${id}" 
                      type="${type || 'text'}" 
                      value="${value || ''}"
                      placeholder="${placeholder || ''}"
                      class="w-full bg-surface-container-low border border-outline-variant rounded-xl ${icon ? 'pl-12' : 'px-4'} ${ (type === 'password' && showPasswordToggle) ? 'pr-11' : 'pr-4' } py-3.5 text-sm text-on-surface placeholder:text-outline focus:border-primary focus:ring-1 focus:ring-primary/20 transition-all outline-none disabled:opacity-50 disabled:cursor-not-allowed"
                      ${required ? 'required' : ''}
                      ${disabled ? 'disabled' : ''}
                    >
                    ${ (type === 'password' && showPasswordToggle) ? `
                      <button type="button" 
                        class="absolute right-4 top-0 bottom-0 flex items-center text-on-secondary-container hover:text-primary transition-colors outline-none"
                        onclick="const input = document.getElementById('${id}'); const icon = this.querySelector('span'); if (input.type === 'password') { input.type = 'text'; icon.textContent = 'visibility_off'; } else { input.type = 'password'; icon.textContent = 'visibility'; }">
                        <span class="material-symbols-outlined text-lg">visibility</span>
                      </button>
                    ` : '' }
                  </div>
                  ${hint ? `<p id="${id}-hint" class="text-[10px] text-outline font-medium px-1 leading-relaxed">${hint}</p>` : ''}
                </div>
              `;
            };

            const accountInfoBody = `
              <div class="space-y-6">
                ${renderInput({
                  id: 'username-display',
                  label: 'Username',
                  value: admin.username,
                  disabled: true,
                  icon: 'person',
                  hint: '<span class="material-symbols-outlined text-[14px] align-middle mr-1">lock</span> Username cannot be changed for security reasons.'
                })}
              </div>
            `;
          %>
          <%- include('components/card', {
            title: 'Account Information',
            icon: 'badge',
            body: accountInfoBody
          }) %>


          <!-- Password Section -->
          <%
            const securityBody = `
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                ${renderInput({
                  id: 'new-password',
                  type: 'password',
                  label: 'New Password',
                  icon: 'lock_open',
                  placeholder: '••••••••',
                  showPasswordToggle: true
                })}
                ${renderInput({
                  id: 'confirm-password',
                  type: 'password',
                  label: 'Confirm Password',
                  icon: 'verified',
                  placeholder: '••••••••',
                  showPasswordToggle: true
                })}
              </div>

              <div class="mt-6 flex items-start gap-4 p-5 bg-surface-container-low rounded-xl border border-outline-variant">
                <span class="material-symbols-outlined text-primary">info</span>
                <div>
                  <h4 class="text-sm font-bold text-on-surface mb-1">Security Tip</h4>
                  <p class="text-xs text-on-secondary-container leading-relaxed">Ensure your password is at least 8 characters long and contains a mix of letters, numbers, and symbols.</p>
                </div>
              </div>



              <div class="pt-6 flex justify-end">
                <button id="save-profile-btn" type="submit" class="w-full md:w-auto bg-primary text-white px-6 py-3 rounded-xl text-sm font-semibold shadow-lg shadow-red-100 hover:opacity-90 active:scale-95 transition-all uppercase tracking-wider flex items-center justify-center gap-2">
                  <span class="material-symbols-outlined">save</span>
                  <span>SAVE CHANGES</span>
                </button>
              </div>
            `;
          %>

          <%- include('components/card', {
            title: 'Security & Password',
            icon: 'security',
            body: securityBody
          }) %>


        </form>
      </div>
    </div>
  </main>

<%- include('layouts/footer', { extraScripts: '<script src="/js/admin-profile.js"></script>' }) %>

