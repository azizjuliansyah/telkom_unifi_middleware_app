<% 
  const _variant = locals.variant || 'primary';
  const _iconOnly = locals.iconOnly || false;
  const _className = locals.className || '';
  const _id = locals.id || '';
  const _submit = locals.submit || false;
  const _disabled = locals.disabled || false;
  const _icon = locals.icon || '';
  const _text = locals.text || '';

  const variants = {
    primary: "bg-primary text-white shadow-lg shadow-red-100 hover:opacity-90 active:scale-95",
    secondary: "bg-white border border-outline-variant text-on-secondary-container hover:bg-surface-container-high transition-colors",
    danger: "bg-red-50 text-primary border border-red-100 hover:bg-red-100 transition-colors",
    ghost: "text-on-secondary-container hover:text-on-surface transition-colors",
    icon: "p-2 border border-outline-variant bg-white text-on-secondary-container hover:bg-surface-container-high transition-colors rounded-lg disabled:opacity-30 disabled:cursor-not-allowed"
  };

  const baseClass = "flex items-center justify-center gap-2 font-bold transition-all uppercase tracking-wider disabled:opacity-50 disabled:cursor-not-allowed";
  const sizeClass = _iconOnly ? "p-2" : "px-6 py-2 rounded-xl text-sm";
  
  const variantClass = variants[_variant] || variants.primary;
  const finalClass = `${baseClass} ${sizeClass} ${variantClass} ${_className}`;
%>

<button 
  id="<%= _id %>" 
  type="<%= _submit ? 'submit' : 'button' %>" 
  class="<%= finalClass %>"
  <%= _disabled ? 'disabled' : '' %>
>
  <% if (_icon) { %>
    <span class="material-symbols-outlined text-md"><%= _icon %></span>
  <% } %>
  <% if (!_iconOnly && _text) { %>
    <%= _text %>
  <% } %>
</button>

