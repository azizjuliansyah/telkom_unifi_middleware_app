<%
  const _id = locals.id || 'modal';
  const _title = locals.title || 'Modal Title';
  const _size = locals.size || 'md';
  const _body = locals.body || '';
  const _footer = locals.footer || '';

  const sizes = {
    sm: "max-w-sm",
    md: "max-w-md",
    lg: "max-w-lg",
    xl: "max-w-xl",
    "2xl": "max-w-2xl"
  };
  const sizeClass = sizes[_size] || sizes.md;
%>

<div id="<%= _id %>-overlay" class="fixed inset-0 bg-black/60 z-[100] flex items-center justify-center p-4 backdrop-blur-sm hidden" onclick="if(event.target === this) { this.classList.add('hidden'); }">
  <div class="bg-white w-full <%= sizeClass %> shadow-2xl overflow-hidden rounded-2xl transform transition-all border border-outline-variant">
    <div class="px-6 py-5 border-b border-outline-variant flex justify-between items-center bg-surface-container-low">
      <h3 id="<%= _id %>-title" class="text-lg font-bold text-on-surface"><%= _title %></h3>
      <button id="<%= _id %>-close" class="material-symbols-outlined text-on-secondary-container hover:text-primary transition-colors">close</button>
    </div>
    
    <div class="p-8">
      <%- _body %>
    </div>

    <% if (_footer) { %>
      <div class="px-8 py-5 border-t border-outline-variant bg-surface-container-low flex justify-end gap-3">
        <%- _footer %>
      </div>
    <% } %>
  </div>
</div>

