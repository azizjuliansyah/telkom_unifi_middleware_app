<!DOCTYPE html>
<html lang="id">

<head>
  <%- include('partials/head') %>
    <title>Koneksi Diperlukan - Unifi Portal</title>
</head>

<body class="bg-gray-50 h-screen flex items-center justify-center p-6">
  <div class="max-w-md w-full text-center">
    <div class="mb-8 relative inline-block">
      <div
        class="w-24 h-24 bg-red-50 text-red-500 rounded-full flex items-center justify-center mx-auto border-4 border-white shadow-xl">
        <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.268 16c-.77 1.333.192 3 1.732 3z">
          </path>
        </svg>
      </div>
      <div class="absolute -bottom-2 -right-2 w-8 h-8 bg-white rounded-full flex items-center justify-center shadow-md">
        <div class="w-4 h-4 bg-red-500 rounded-full animate-ping"></div>
      </div>
    </div>

    <h1 class="text-4xl font-bold text-gray-900 mb-3">Sesi Tidak Valid</h1>
    <p class="text-gray-500 mb-10 leading-relaxed">
      <%= message
        || "Kami tidak dapat mengidentifikasi perangkat Anda. Silakan hubungkan kembali perangkat Anda ke jaringan WiFi untuk mengakses portal."
        %>
    </p>

    <div class="mt-12">
      <%- include('partials/footer-logos') %>
    </div>
  </div>
</body>

</html>