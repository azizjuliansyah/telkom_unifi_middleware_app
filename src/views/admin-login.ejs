<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head') %>
  <title>Admin Login - Unifi Captive Portal</title>
</head>
<body class="bg-gray-50 h-screen flex items-center justify-center p-6 font-sans">
  <div class="max-w-md w-full bg-white rounded-[2rem] shadow-2xl shadow-red-900/5 border border-gray-100 overflow-hidden">
    <div class="p-8 sm:p-12">
      <div class="flex justify-center mb-8">
        <div class="bg-red-50 p-4 rounded-2xl border border-red-100">
          <svg class="w-10 h-10 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
          </svg>
        </div>
      </div>

      <div class="text-center mb-10">
        <div class="inline-block px-3 py-1 bg-red-50 text-red-600 text-[10px] font-bold tracking-[0.2em] rounded-full border border-red-100 mb-4 uppercase">
          Admin Control Panel
        </div>
        <h1 class="text-2xl font-black text-gray-900 mb-2">Admin Login</h1>
        <p class="text-gray-500 text-sm">Masuk untuk mengelola user portal.</p>
      </div>

      <div id="error-msg" class="hidden mb-6 p-4 bg-red-500/10 border border-red-500/20 text-red-400 rounded-2xl text-sm text-center"></div>

      <form id="login-form" class="space-y-6">
        <div>
          <label for="username" class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Username</label>
          <input type="text" id="username" name="username" required
                 class="w-full px-5 py-4 bg-gray-50 border border-gray-100 rounded-2xl focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all outline-none text-gray-900 placeholder-gray-300"
                 placeholder="Admin username">
        </div>

        <div>
          <label for="password" class="block text-xs font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Password</label>
          <input type="password" id="password" name="password" required
                 class="w-full px-5 py-4 bg-gray-50 border border-gray-100 rounded-2xl focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all outline-none text-gray-900 placeholder-gray-300"
                 placeholder="••••••••">
        </div>

        <button type="submit" id="submit-btn" 
                class="w-full py-4 bg-red-600 hover:bg-red-700 text-white font-bold rounded-2xl shadow-lg shadow-red-200 transition-all transform active:scale-95">
          Login Ke Dashboard
        </button>
      </form>

      <div class="mt-10 text-center">
        <a href="/guest/s/default/" class="text-xs font-bold text-gray-400 hover:text-red-600 transition-colors uppercase tracking-widest">
          &larr; Kembali ke Portal
        </a>
      </div>
    </div>
  </div>

  <script src="/js/admin-login.js"></script>
</body>
</html>
