<%- include('layouts/header', { 
    title: 'Admin Login - Telkom Admin Portal', 
    bodyClass: 'bg-surface-bright min-h-screen flex items-center justify-center p-gutter' 
}) %>
    <main class="w-full max-w-[440px]">
        <% 
            const loginFormHtml = `
                <!-- Logo Section -->
                <div class="flex flex-col items-center mb-10">
                    <img src="/images/telkominfra-favicon.png" alt="TelkomInfra Logo" class="w-20 h-20 object-contain mb-6 drop-shadow-xl">
                    <h1 class="text-on-surface font-extrabold text-3xl tracking-tight text-center">Admin Portal</h1>
                    <p class="text-on-secondary-container font-medium text-center mt-2 text-sm">Telkom Indonesia Admin Management</p>
                </div>



                <!-- Login Form -->
                <form id="login-form" class="space-y-3">
                    ${include('components/input', {
                        id: 'username',
                        label: 'Username',
                        icon: 'person',
                        placeholder: 'Admin username',
                        required: true,
                        className: 'h-12'
                    })}

                    ${include('components/input', {
                        id: 'password',
                        type: 'password',
                        label: 'Password',
                        icon: 'lock',
                        placeholder: '••••••••',
                        required: true,
                        showPasswordToggle: true,
                        className: 'h-12'
                    })}

                    <div class="pt-2">
                        ${include('components/button', {
                            id: 'submit-btn',
                            submit: true,
                            text: 'Login',
                            variant: 'primary',
                            className: 'w-full h-12'
                        })}
                    </div>
                </form>
            `;
        %>

        <%- include('components/card', {
            className: 'shadow-2xl border-outline-variant',
            bodyClassName: 'p-10',
            body: loginFormHtml
        }) %>


        <div class="text-center mt-2">
            <span class="text-xs text-secondary">© <%= new Date().getFullYear() %> Telkom Indonesia.</span>
        </div>
    </main>

<% const loginScripts = `
    <script src="/js/admin-login.js"></script>
`; %>

<%- include('layouts/footer', { extraScripts: loginScripts }) %>


