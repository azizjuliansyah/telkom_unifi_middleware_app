<!DOCTYPE html>
<html lang="id">
<head>
  <%- include('partials/head') %>
  <title>Dashboard Admin - Unifi Captive Portal</title>
</head>
<body class="bg-gray-50 flex h-screen overflow-hidden">
  
  <%- include('partials/admin-sidebar') %>

  <!-- Main Content -->
  <main class="flex-1 flex flex-col min-w-0 overflow-hidden">
    <header class="h-20 bg-white border-b border-gray-100 flex items-center justify-between px-8 shrink-0">
      <h2 class="text-xl font-black text-gray-800 tracking-tight">User Management</h2>
      <button id="add-user-btn" class="px-6 py-2.5 bg-red-600 hover:bg-red-700 text-white rounded-xl font-bold shadow-lg shadow-red-100 flex items-center space-x-2 transition-all active:scale-95 text-sm uppercase tracking-widest">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
        </svg>
        <span>Tambah User</span>
      </button>
    </header>

    <div class="flex-1 overflow-auto p-8">
      <div class="bg-white rounded-2xl shadow-sm border border-gray-200 overflow-hidden">
        <div class="min-w-full overflow-x-auto">
          <table class="min-w-full divide-y divide-gray-200">
            <thead class="bg-gray-50/50">
              <tr>
                <th class="px-6 py-5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em]">No</th>
                <th class="px-6 py-5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em]">Username</th>
                <th class="px-6 py-5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em]">Nama Lengkap</th>
                <th class="px-6 py-5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em]">Status</th>
                <th class="px-6 py-5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em]">Dibuat</th>
                <th class="px-6 py-5 text-left text-[10px] font-bold text-gray-400 uppercase tracking-[0.2em] text-center">Aksi</th>
              </tr>
            </thead>
            <tbody id="users-tbody" class="bg-white divide-y divide-gray-200">
              <!-- Content via JS -->
            </tbody>
          </table>
        </div>

        <div id="loading-state" class="py-20 text-center">
          <div class="inline-block animate-spin rounded-full h-8 w-8 border-4 border-red-600 border-t-transparent mb-4"></div>
          <p class="text-gray-400 text-sm font-medium">Memuat data user...</p>
        </div>

        <div id="empty-state" class="hidden py-20 text-center">
          <div class="bg-gray-100 w-20 h-20 rounded-full flex items-center justify-center mx-auto mb-6 text-gray-400 border border-dashed border-gray-300">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-bold text-gray-800 mb-2">Belum ada user</h3>
          <p class="text-gray-400 text-sm max-w-xs mx-auto">Mulai dengan menambahkan user lokal yang dapat mengakses portal tanpa API eksternal.</p>
        </div>
      </div>
    </div>
  </main>

  <!-- Modal Overlay -->
  <div id="modal-overlay" class="fixed inset-0 bg-gray-900/40 backdrop-blur-[2px] hidden items-center justify-center z-[100] p-4">
    <div class="bg-white rounded-[2rem] shadow-2xl w-full max-w-lg overflow-hidden transform transition-all border border-gray-100">
      <div class="px-8 py-6 border-b border-gray-100 flex items-center justify-between">
        <h2 id="modal-title" class="text-xl font-bold text-gray-800">Tambah User</h2>
        <button id="modal-close" class="text-gray-400 hover:text-gray-600 transition-colors">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </button>
      </div>
      
      <div class="p-8">
        <input type="hidden" id="user-id">
        <div class="space-y-5">
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Username *</label>
            <input type="text" id="field-username" placeholder="cth: budi_unifi"
                   class="w-full px-4 py-3.5 bg-gray-50 border border-gray-100 rounded-xl focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all outline-none text-sm">
          </div>
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Nama Lengkap</label>
            <input type="text" id="field-fullname" placeholder="cth: Budi Setiawan"
                   class="w-full px-4 py-3.5 bg-gray-50 border border-gray-100 rounded-xl focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all outline-none text-sm">
          </div>
          <div>
            <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Password *</label>
            <input type="password" id="field-password" placeholder="••••••••"
                   class="w-full px-4 py-3.5 bg-gray-50 border border-gray-100 rounded-xl focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all outline-none text-sm">
            <small id="password-hint" class="hidden text-[10px] text-gray-400 mt-2 italic font-medium">Kosongkan jika tidak ingin mengubah password</small>
          </div>
          <div id="status-group" class="hidden">
            <label class="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2 ml-1">Status</label>
            <select id="field-status" class="w-full px-4 py-3.5 bg-gray-50 border border-gray-100 rounded-xl focus:ring-2 focus:ring-red-500 focus:border-red-500 transition-all outline-none appearance-none text-sm font-bold">
              <option value="1">Aktif</option>
              <option value="0">Nonaktif</option>
            </select>
          </div>
        </div>
        <div id="modal-error" class="hidden mt-6 p-4 bg-red-50 border border-red-200 text-red-600 rounded-xl text-sm font-medium"></div>
      </div>

      <div class="px-8 py-6 bg-gray-50/50 flex justify-end space-x-3 border-t border-gray-100">
        <button id="modal-cancel" class="px-6 py-3 text-[10px] font-black text-gray-400 uppercase tracking-[0.2em] hover:text-gray-600 transition-colors">Batal</button>
        <button id="modal-save" class="px-10 py-3 bg-red-600 hover:bg-red-700 text-white text-[10px] font-black uppercase tracking-[0.2em] rounded-xl shadow-lg shadow-red-100 transition-all active:scale-95">Simpan</button>
      </div>
    </div>
  </div>

  <!-- Delete Confirmation Modal -->
  <div id="delete-overlay" class="fixed inset-0 bg-gray-900/40 backdrop-blur-[2px] hidden items-center justify-center z-[110] p-4">
    <div class="bg-white rounded-[2rem] shadow-2xl w-full max-w-sm overflow-hidden transform transition-all border border-gray-100">
      <div class="p-8 text-center">
        <div class="w-16 h-16 bg-red-50 text-red-600 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
          </svg>
        </div>
        <h2 class="text-xl font-bold text-gray-800 mb-2">Hapus User?</h2>
        <p id="delete-confirm-text" class="text-gray-500 text-sm">Apakah Anda yakin ingin menghapus user ini secara permanen?</p>
      </div>
      <div class="p-6 bg-gray-50 flex space-x-3">
        <button id="delete-cancel" class="flex-1 py-3 text-sm font-bold text-gray-500 uppercase tracking-widest hover:text-gray-700 transition-colors">Batal</button>
        <button id="delete-confirm" class="flex-1 py-3 bg-red-600 hover:bg-red-700 text-white text-sm font-bold uppercase tracking-widest rounded-xl shadow-lg shadow-red-100 transition-all active:scale-95">Hapus</button>
      </div>
    </div>
  </div>

  <script src="/js/admin.js"></script>
</body>
</html>
