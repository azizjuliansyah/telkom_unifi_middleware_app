<%- include('layouts/header', { title: 'User Management - Telkom Admin' }) %>

  <%- include('partials/admin-header') %>

  <!-- Main Content -->
  <main class="mt-16 flex-grow max-w-container-max-width mx-auto w-full px-margin-x py-margin-y flex flex-col">
    <!-- Breadcrumbs -->
    <%- include('components/breadcrumb', {
      items: [
        { label: 'Dashboard', href: '/admin' },
        { label: 'User Management', active: true }
      ]
    }) %>


    <!-- Header Section -->
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-stack-md mb-stack-sm">
      <div>
        <h1 class="text-3xl font-extrabold tracking-tight text-on-surface mb-1">User Management</h1>
        <p class="text-[15px] text-on-secondary-container font-medium">Administer access controls and user credentials across the infrastructure.</p>
      </div>
      <%- include('components/button', {
        id: 'add-user-btn',
        text: 'ADD NEW USER',
        icon: 'person_add',
        variant: 'primary',
        size: 'sm'
      }) %>

    </div>

    <!-- Action Bar -->
    <div class="bg-white border border-outline-variant p-stack-md flex flex-col md:flex-row gap-stack-md items-center justify-between rounded-t-2xl shadow-sm">
      <%- include('components/input', {
        id: 'search-input',
        type: 'text',
        placeholder: 'Search by name, username, or role...',
        icon: 'search',
        containerClass: 'w-full md:w-96'
      }) %>

    </div>

    <div class="bg-white border border-outline-variant border-t-0 rounded-b-2xl shadow-sm overflow-hidden flex-grow flex flex-col min-h-[500px]">
      <%- include('components/table', {
        id: 'users-tbody',
        className: 'flex-grow',
        headers: [
          'No', 'Username', 'Full Name', 'Status', 'Created At', 'Updated At','Actions'
        ],
        body: `
          <!-- Content via JS -->
        `
      }) %>

      <!-- States -->
      <%- include('components/states', {
        type: 'loading',
        id: 'loading-state',
        text: 'Memuat data user...'
      }) %>

      <%- include('components/states', {
        type: 'empty',
        id: 'empty-state',
        icon: 'person_off',
        title: 'Belum ada user',
        subtext: 'Mulai dengan menambahkan user lokal yang dapat mengakses portal tanpa API eksternal.'
      }) %>

      <%- include('components/pagination', {
        infoId: 'pagination-info',
        infoText: 'Showing 0 to 0 of 0 users',
        prevId: 'prev-page',
        nextId: 'next-page',
        numbersId: 'page-numbers'
      }) %>
    </div>

  </main>

  <!-- User Modal -->
  <% 
    const renderSelect = (args) => {
      const { id, label, options, containerClass } = args;
      return `
        <div id="${id}-group" class="space-y-1.5 ${containerClass || ''}">
          ${label ? `<label for="${id}" class="block text-xs font-bold text-on-secondary-container uppercase tracking-widest">${label}</label>` : ''}
          <select id="${id}" class="w-full bg-surface-container-low border border-outline-variant rounded-xl px-4 py-3.5 text-sm text-on-surface focus:border-primary focus:ring-1 focus:ring-primary/20 transition-all outline-none appearance-none">
            ${options.map(opt => `<option value="${opt.value}">${opt.text}</option>`).join('')}
          </select>
        </div>
      `;
    };

    const modalBody = `
      <input type="hidden" id="user-id">
      <div class="space-y-6">
        ${ include('components/input', {
          id: 'field-username',
          label: 'Username',
          icon: 'person',
          placeholder: 'cth: budi_unifi',
          required: true
        }) }
        ${ include('components/input', {
          id: 'field-fullname',
          label: 'Full Name',
          icon: 'badge',
          placeholder: 'cth: Budi Setiawan'
        }) }
        ${ include('components/input', {
          id: 'field-password',
          type: 'password',
          label: 'Password',
          icon: 'lock',
          placeholder: '••••••••',
          required: true,
          showPasswordToggle: true,
          hint: 'Kosongkan jika tidak ingin mengubah password'
        }) }
        ${renderSelect({
          id: 'field-status',
          label: 'Status',
          containerClass: 'hidden',
          options: [
            { value: '1', text: 'Aktif' },
            { value: '0', text: 'Nonaktif' }
          ]
        })}
      </div>
    `;

    const modalFooter = `
      ${ include('components/button', {
        id: 'modal-cancel',
        text: 'CANCEL',
        variant: 'secondary',
        size: 'md'
      }) }
      ${ include('components/button', {
        id: 'modal-save',
        text: 'SAVE USER',
        variant: 'primary',
        size: 'md'
      }) }
    `;
  %>


  <%- include('components/modal', {
    id: 'modal',
    title: 'Add New User',
    size: 'lg',
    body: modalBody,
    footer: modalFooter
  }) %>



  <!-- Delete Modal -->
  <% 
    const deleteFooter = `
      ${ include('components/button', {
        id: 'delete-cancel',
        text: 'CANCEL',
        variant: 'secondary',
        size: 'md'
      }) }
      ${ include('components/button', {
        id: 'delete-confirm',
        text: 'DELETE',
        variant: 'primary',
        size: 'md'
      }) }
    `;
  %>


  <%- include('components/modal', {
    id: 'delete',
    title: 'Delete User?',
    size: 'sm',
    body: `
      <div class="flex items-start gap-4">
        <div class="flex-shrink-0 w-12 h-12 bg-red-50 text-primary rounded-full flex items-center justify-center border border-red-100">
          ${ include('components/icon', { name: 'delete_forever', className: 'w-6 h-6' }) }
        </div>
        <div class="pt-1">
          <p id="delete-confirm-text" class="text-on-secondary-container text-sm font-medium leading-relaxed">Apakah Anda yakin ingin menghapus user ini secara permanen?</p>
        </div>
      </div>
    `,
    footer: deleteFooter
  }) %>

<%- include('layouts/footer', { extraScripts: '<script src="/js/admin-users.js"></script>' }) %>

